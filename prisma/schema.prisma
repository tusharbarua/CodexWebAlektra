generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
  SHOP_MANAGER
  CUSTOMER
}

enum PublishStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  SSLCOMMERZ
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  UNPAID
  INITIATED
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum IntegrationProvider {
  SOLISCLOUD
  SUNGROW_ISOLARCLOUD
  SMA_SUNNY_PORTAL
  GENERIC
}

enum ThermalInspectionType {
  STANDARD
  COMPREHENSIVE
}

enum ThermalRequestStatus {
  NEW
  REVIEWED
  QUOTED
  AWAITING_PAYMENT
  PAID
  SCHEDULED
  COMPLETED
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(CUSTOMER)
  isActive      Boolean   @default(true)
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  articles      ResourceArticle[] @relation("ArticleAuthor")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SeoMetadata {
  id          String   @id @default(cuid())
  route       String   @unique
  title       String
  description String
  keywords    Json
  ogImage     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteContent {
  id        String        @id @default(cuid())
  key       String        @unique
  title     String
  body      String
  status    PublishStatus @default(PUBLISHED)
  metadata  Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model SiteSettings {
  id                String   @id @default(cuid())
  singletonKey      String   @unique @default("footer")
  contactEmail      String   @default("contact@alektraepc.com")
  contactPhone      String   @default("+880 1735954 844")
  address           String   @default("Dhaka, Bangladesh")
  facebookUrl       String?
  linkedinUrl       String?
  youtubeUrl        String?
  whatsappNumber    String?
  footerDescription String   @default("Solar EPC, thermal inspection, cleaning and mapping for renewable-energy assets in Bangladesh.")
  copyrightText     String   @default("Copyright (c) Alektra Renewable. All rights reserved.")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model HeroMedia {
  id          String        @id @default(cuid())
  title       String
  mediaType   String
  url         String
  alt         String
  sortOrder   Int           @default(0)
  isPrimary   Boolean       @default(false)
  status      PublishStatus @default(PUBLISHED)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Project {
  id                String        @id @default(cuid())
  title             String
  slug              String        @unique
  clientName        String?
  location          String
  projectType       String
  capacityKw        Decimal
  commissionedAt    DateTime?
  coverImage        String?
  summary           String
  fullCaseStudy     String        @default("")
  inverterBrandModel String?
  moduleBrandModel  String?
  imageUrls         Json?
  videoUrl          String?
  annualGeneration  Decimal?
  annualSavingsBdt  Decimal?
  status            PublishStatus @default(PUBLISHED)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model ImpactSnapshot {
  id                       String   @id @default(cuid())
  plantsInOperation        Int
  totalInstalledCapacityKw Decimal
  kwhGenerated             Decimal
  equivalentTreesPlanted   Decimal
  co2OffsetTons            Decimal
  longHaulFlightsAvoided   Decimal
  manualBaselineJson       Json
  lastCalculatedAt         DateTime @default(now())
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model ImpactDailyLedger {
  id              String              @id @default(cuid())
  source          String
  provider        IntegrationProvider?
  externalPlantId String?
  date            DateTime
  kwhGenerated    Decimal
  co2OffsetTons   Decimal
  treesEquivalent Decimal
  flightsAvoided  Decimal
  rawPayload      Json?
  createdAt       DateTime            @default(now())

  @@unique([source, externalPlantId, date])
}

model MonitoringIntegration {
  id           String              @id @default(cuid())
  provider     IntegrationProvider
  label        String
  baseUrl      String?
  apiKey       String?
  apiSecret    String?
  username     String?
  password     String?
  isEnabled    Boolean             @default(false)
  lastSyncAt   DateTime?
  settings     Json?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model ResourceCategory {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  description String
  sortOrder   Int               @default(0)
  articles    ResourceArticle[]
}

model ResourceArticle {
  id           String           @id @default(cuid())
  title        String
  slug         String           @unique
  excerpt      String
  body         String
  coverImage   String?
  status       PublishStatus    @default(DRAFT)
  categoryId   String
  authorId     String?
  publishedAt  DateTime?
  seoTitle     String?
  seoDescription String?
  category     ResourceCategory @relation(fields: [categoryId], references: [id])
  author       User?            @relation("ArticleAuthor", fields: [authorId], references: [id])
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model ProductCategory {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  description String?
  parentId    String?
  parent      ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    ProductCategory[] @relation("CategoryTree")
  products    Product[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Product {
  id                   String          @id @default(cuid())
  name                 String
  slug                 String          @unique
  sku                  String          @unique
  model                String
  brand                String
  priceBdt             Decimal
  compareAtPriceBdt    Decimal?
  stockQuantity        Int
  isFeatured           Boolean         @default(false)
  status               PublishStatus   @default(DRAFT)
  shortDescription     String
  technicalDescription String
  datasheetUrl         String?
  manualUrl            String?
  specifications       Json
  categoryId           String
  category             ProductCategory @relation(fields: [categoryId], references: [id])
  images               ProductImage[]
  orderItems           OrderItem[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  imagePath String
  altText   String
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Coupon {
  id             String    @id @default(cuid())
  code           String    @unique
  description    String?
  discountType   String
  amount         Decimal
  minimumSpend   Decimal?
  startsAt       DateTime?
  expiresAt      DateTime?
  usageLimit     Int?
  usedCount      Int       @default(0)
  isActive       Boolean   @default(true)
  orders         Order[]
}

model DeliveryCharge {
  id          String   @id @default(cuid())
  zone        String   @unique
  description String?
  chargeBdt   Decimal
  freeAboveBdt Decimal?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  userId          String?
  customerName    String
  customerEmail   String
  customerPhone   String
  billingAddress  Json
  shippingAddress Json
  subtotalBdt     Decimal
  discountBdt     Decimal       @default(0)
  deliveryBdt     Decimal       @default(0)
  totalBdt        Decimal
  status          OrderStatus   @default(PENDING)
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(UNPAID)
  couponId        String?
  notes           String?
  items           OrderItem[]
  transactions    PaymentTransaction[]
  user            User?         @relation(fields: [userId], references: [id])
  coupon          Coupon?       @relation(fields: [couponId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  productId      String
  name           String
  sku            String
  quantity       Int
  unitPriceBdt   Decimal
  lineTotalBdt   Decimal
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product @relation(fields: [productId], references: [id])
}

model PaymentTransaction {
  id              String        @id @default(cuid())
  orderId         String
  provider        String
  transactionId   String?       @unique
  validationId    String?
  amountBdt       Decimal
  status          PaymentStatus
  requestPayload  Json?
  responsePayload Json?
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  interest  String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ThermalInspectionRequest {
  id                    String                @id @default(cuid())
  requestNumber         String                @unique
  inspectionType        ThermalInspectionType
  moduleDetails         Json
  pvCapacityKwp         Decimal
  acCapacityKw          Decimal
  projectLocation       String
  latitude              Decimal?
  longitude             Decimal?
  institutionName       String
  address               String
  email                 String
  contactNumber         String
  additionalNotes       String?
  internalNotes         String?
  askForPayment         Boolean               @default(false)
  calculatedFeeBdt      Decimal?
  paymentStatus         PaymentStatus         @default(UNPAID)
  sslTransactionId      String?
  pdfFilePath           String?
  emailSentAt           DateTime?
  adminEmailSentAt      DateTime?
  status                ThermalRequestStatus  @default(NEW)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
}

model ThermalPricingRule {
  id                      String   @id @default(cuid())
  name                    String   @unique
  baseInspectionFeeBdt    Decimal  @default(0)
  ratePerKwpBdt           Decimal  @default(0)
  distanceChargePerKmBdt  Decimal  @default(0)
  minimumInspectionFeeBdt Decimal  @default(0)
  standardMultiplier      Decimal  @default(1)
  comprehensiveMultiplier Decimal  @default(1.5)
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}
