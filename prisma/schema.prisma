generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
  SHOP_MANAGER
  CUSTOMER
}

enum PublishStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
}

enum OrderStatus {
  PENDING
  NEW
  CONFIRMED
  PROCESSING
  READY_FOR_PICKUP
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  SSLCOMMERZ
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  UNPAID
  CASH_ON_DELIVERY
  INITIATED
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum IntegrationProvider {
  SOLISCLOUD
  SUNGROW_ISOLARCLOUD
  SMA_SUNNY_PORTAL
  GENERIC
}

enum ThermalInspectionType {
  STANDARD
  COMPREHENSIVE
}

enum ThermalRequestStatus {
  NEW
  REVIEWED
  QUOTED
  AWAITING_PAYMENT
  PAID
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum PageKey {
  epc
  thermal
  sparkle
  mapping
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  phone         String?
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(CUSTOMER)
  appRoleId     String?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  appRole       AppRole?  @relation(fields: [appRoleId], references: [id])
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  articles      ResourceArticle[] @relation("ArticleAuthor")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model AppRole {
  id          String              @id @default(cuid())
  name        String              @unique
  description String?
  isSystem    Boolean             @default(false)
  users       User[]
  permissions AppRolePermission[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model AppRolePermission {
  id        String   @id @default(cuid())
  roleId    String
  module    String
  action    String
  role      AppRole  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([roleId, module, action])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SeoMetadata {
  id          String   @id @default(cuid())
  route       String   @unique
  title       String
  description String
  keywords    Json
  ogImage     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteContent {
  id        String        @id @default(cuid())
  key       String        @unique
  title     String
  body      String
  status    PublishStatus @default(PUBLISHED)
  metadata  Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Page {
  id              String        @id @default(cuid())
  pageKey         PageKey       @unique
  title           String
  slug            String        @unique
  metaTitle       String?
  metaDescription String?
  status          PublishStatus @default(DRAFT)
  sections        PageSection[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model PageSection {
  id           String            @id @default(cuid())
  pageId       String
  sectionKey   String
  sectionType  String
  title        String
  subtitle     String?
  body         String?
  sortOrder    Int               @default(0)
  isPublished  Boolean           @default(true)
  settingsJson Json?
  page         Page              @relation(fields: [pageId], references: [id], onDelete: Cascade)
  items        PageSectionItem[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([pageId, sectionKey])
}

model PageSectionItem {
  id           String      @id @default(cuid())
  sectionId    String
  title        String
  subtitle     String?
  body         String?
  icon         String?
  imagePath    String?
  videoPath    String?
  linkText     String?
  linkUrl      String?
  badge        String?
  sortOrder    Int         @default(0)
  settingsJson Json?
  isPublished  Boolean     @default(true)
  section      PageSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model SiteSettings {
  id                String   @id @default(cuid())
  singletonKey      String   @unique @default("footer")
  contactEmail      String   @default("contact@alektraepc.com")
  contactPhone      String   @default("+880 1735954 844")
  address           String   @default("Dhaka, Bangladesh")
  facebookUrl       String?
  linkedinUrl       String?
  youtubeUrl        String?
  whatsappNumber    String?
  footerDescription String   @default("Solar EPC, thermal inspection, cleaning and mapping for renewable-energy assets in Bangladesh.")
  copyrightText     String   @default("Copyright (c) Alektra Renewable. All rights reserved.")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model HeroMedia {
  id          String        @id @default(cuid())
  title       String
  mediaType   String
  url         String
  alt         String
  mimeType    String?
  fileSize    Int?
  sortOrder   Int           @default(0)
  isPrimary   Boolean       @default(false)
  status      PublishStatus @default(PUBLISHED)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Project {
  id                String        @id @default(cuid())
  title             String
  slug              String        @unique
  clientName        String?
  location          String
  projectType       String
  capacityKw        Decimal
  commissionedAt    DateTime?
  coverImage        String?
  summary           String
  fullCaseStudy     String        @default("")
  inverterBrandModel String?
  moduleBrandModel  String?
  imageUrls         Json?
  images            ProjectImage[]
  videoUrl          String?
  annualGeneration  Decimal?
  annualSavingsBdt  Decimal?
  status            PublishStatus @default(PUBLISHED)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model ProjectImage {
  id        String   @id @default(cuid())
  projectId String
  imagePath String
  altText   String
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ImpactSnapshot {
  id                       String   @id @default(cuid())
  plantsInOperation        Int
  totalInstalledCapacityKw Decimal
  kwhGenerated             Decimal
  equivalentTreesPlanted   Decimal
  co2OffsetTons            Decimal
  longHaulFlightsAvoided   Decimal
  manualBaselineJson       Json
  lastCalculatedAt         DateTime @default(now())
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model ImpactDailyLedger {
  id              String              @id @default(cuid())
  source          String
  provider        IntegrationProvider?
  externalPlantId String?
  date            DateTime
  kwhGenerated    Decimal
  co2OffsetTons   Decimal
  treesEquivalent Decimal
  flightsAvoided  Decimal
  rawPayload      Json?
  createdAt       DateTime            @default(now())

  @@unique([source, externalPlantId, date])
}

model MonitoringIntegration {
  id           String              @id @default(cuid())
  provider     IntegrationProvider
  label        String
  baseUrl      String?
  apiKey       String?
  apiSecret    String?
  username     String?
  password     String?
  plantMapping String?
  syncFrequencyMinutes Int         @default(1440)
  isEnabled    Boolean             @default(false)
  lastSyncAt   DateTime?
  lastSyncStatus String?
  lastSyncMessage String?
  errorLog     String?
  settings     Json?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model ResourceCategory {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  description String
  sortOrder   Int               @default(0)
  articles    ResourceArticle[]
}

model ResourceArticle {
  id           String           @id @default(cuid())
  title        String
  slug         String           @unique
  excerpt      String
  body         String
  coverImage   String?
  coverImageAlt String?
  status       PublishStatus    @default(DRAFT)
  categoryId   String
  authorId     String?
  publishedAt  DateTime?
  seoTitle     String?
  seoDescription String?
  category     ResourceCategory @relation(fields: [categoryId], references: [id])
  author       User?            @relation("ArticleAuthor", fields: [authorId], references: [id])
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model ProductCategory {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  description String?
  icon        String?
  sortOrder   Int               @default(0)
  status      PublishStatus     @default(PUBLISHED)
  parentId    String?
  parent      ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    ProductCategory[] @relation("CategoryTree")
  products    Product[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Product {
  id                   String          @id @default(cuid())
  name                 String
  slug                 String          @unique
  sku                  String          @unique
  model                String
  brand                String
  priceBdt             Decimal
  compareAtPriceBdt    Decimal?
  stockQuantity        Int
  isFeatured           Boolean         @default(false)
  status               PublishStatus   @default(DRAFT)
  shortDescription     String
  technicalDescription String
  datasheetUrl         String?
  manualUrl            String?
  specifications       Json
  categoryId           String
  category             ProductCategory @relation(fields: [categoryId], references: [id])
  images               ProductImage[]
  orderItems           OrderItem[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  imagePath String
  altText   String
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Coupon {
  id             String    @id @default(cuid())
  code           String    @unique
  description    String?
  discountType   String
  amount         Decimal
  minimumSpend   Decimal?
  startsAt       DateTime?
  expiresAt      DateTime?
  usageLimit     Int?
  usedCount      Int       @default(0)
  isActive       Boolean   @default(true)
  orders         Order[]
}

model DeliveryCharge {
  id          String   @id @default(cuid())
  zone        String   @unique
  description String?
  chargeBdt   Decimal
  freeAboveBdt Decimal?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EcommerceDeliverySetting {
  id                    String   @id @default(cuid())
  singletonKey          String   @unique @default("default")
  courierEnabled        Boolean  @default(true)
  courierMinimumChargeBdt Decimal @default(200)
  pickupEnabled         Boolean  @default(true)
  pickupLabel           String   @default("Pick up from our warehouse")
  pickupAddress         String   @default("Khulshi, Chattogram")
  pickupChargeBdt       Decimal  @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model MessagingIntegration {
  id                       String   @id @default(cuid())
  singletonKey             String   @unique @default("default")
  providerName             String   @default("Not configured")
  baseUrl                  String?
  apiKey                   String?
  senderId                 String?
  otpTemplate              String   @default("Your Alektra Renewable OTP is [OTP]. It expires in 5 minutes.")
  orderConfirmationTemplate String  @default("Your Alektra Renewable order #[ORDER_NUMBER] has been received. Total: BDT [TOTAL]. We will contact you shortly.")
  isEnabled                Boolean  @default(false)
  lastTestStatus           String?
  lastTestAt               DateTime?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model OtpVerification {
  id          String    @id @default(cuid())
  mobile      String
  codeHash    String
  purpose     String    @default("checkout")
  expiresAt   DateTime
  verifiedAt  DateTime?
  attempts    Int       @default(0)
  resendCount Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([mobile, purpose, expiresAt])
}

model NotificationLog {
  id          String   @id @default(cuid())
  orderId     String?
  channel     String
  recipient   String
  status      String
  message     String
  provider    String?
  response    String?
  createdAt   DateTime @default(now())
  order       Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  userId          String?
  customerName    String
  customerEmail   String?
  customerPhone   String
  companyName     String?
  verifiedMobile  String?
  billingAddress  Json
  shippingAddress Json
  deliveryMethod  String    @default("COURIER")
  deliveryLabel   String?
  deliveryNotes   String?
  subtotalBdt     Decimal
  discountBdt     Decimal       @default(0)
  deliveryBdt     Decimal       @default(0)
  totalBdt        Decimal
  status          OrderStatus   @default(PENDING)
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(UNPAID)
  couponId        String?
  notes           String?
  smsStatus       String    @default("NOT_CONFIGURED")
  emailStatus     String    @default("NOT_CONFIGURED")
  items           OrderItem[]
  transactions    PaymentTransaction[]
  notifications   NotificationLog[]
  user            User?         @relation(fields: [userId], references: [id])
  coupon          Coupon?       @relation(fields: [couponId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  productId      String
  name           String
  sku            String
  quantity       Int
  unitPriceBdt   Decimal
  lineTotalBdt   Decimal
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product @relation(fields: [productId], references: [id])
}

model PaymentTransaction {
  id              String        @id @default(cuid())
  orderId         String
  provider        String
  transactionId   String?       @unique
  validationId    String?
  amountBdt       Decimal
  status          PaymentStatus
  requestPayload  Json?
  responsePayload Json?
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  interest  String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ThermalInspectionRequest {
  id                    String                @id @default(cuid())
  requestNumber         String                @unique
  inspectionType        ThermalInspectionType
  moduleDetails         Json
  pvCapacityKwp         Decimal
  acCapacityKw          Decimal
  projectLocation       String
  projectLocationName   String?
  projectFormattedAddress String?
  googlePlaceId         String?
  latitude              Decimal?
  longitude             Decimal?
  manualAddressFallback String?
  distanceFromBaseKm    Decimal?
  distanceCalculationStatus String @default("missing_project_coordinates")
  institutionName       String
  address               String
  email                 String
  contactNumber         String
  additionalNotes       String?
  internalNotes         String?
  askForPayment         Boolean               @default(false)
  calculatedFeeBdt      Decimal?
  paymentStatus         PaymentStatus         @default(UNPAID)
  sslTransactionId      String?
  pdfFilePath           String?
  emailSentAt           DateTime?
  adminEmailSentAt      DateTime?
  status                ThermalRequestStatus  @default(NEW)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
}

model ThermalBaseLocation {
  id           String   @id @default(cuid())
  singletonKey String  @unique @default("default")
  name         String  @default("Alektra Renewable Base")
  address      String?
  googlePlaceId String?
  latitude     Decimal @default(22.3585575)
  longitude    Decimal @default(91.8196934)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ThermalPricingRule {
  id                      String   @id @default(cuid())
  name                    String   @unique
  baseInspectionFeeBdt    Decimal  @default(0)
  ratePerKwpBdt           Decimal  @default(0)
  distanceChargePerKmBdt  Decimal  @default(0)
  minimumInspectionFeeBdt Decimal  @default(0)
  standardMultiplier      Decimal  @default(1)
  comprehensiveMultiplier Decimal  @default(1.5)
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}
